{
  "name": "minigameday",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc && tsc -p dashboard",
    "watch": "tsc -w",
    "test": "vp test run",
    "test:watch": "vp test",
    "prepare": "lefthook install",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "dashboard": "vp dev dashboard --open",
    "dashboard:build": "vp build dashboard",
    "cdk": "cdk",
    "synth": "cdk synth",
    "synth:nag": "cdk synth -c nag=true --quiet",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all",
    "destroy": "cdk destroy --all",
    "drift": "cdk drift"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-fis": "^3.1085.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "@voidzero-dev/vite-plus-core": "^0.2.2",
    "aws-cdk": "2.1126.0",
    "cdk-nag": "^2.38.2",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "oxlint-plugin-awscdk": "^0.1.3",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "vite-plus": "^0.2.2",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.258.1",
    "constructs": "^10.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "^11.16.0",
      "onFail": "download"
    }
  }
}

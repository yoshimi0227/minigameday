# CDK (tsc は noEmit 運用。*.js の一括 ignore は不要 — app/ canaries/ dashboard/ の .js はソース)
cdk.out/
node_modules/

# Dashboard build artifacts
dashboard/dist/

# GameDay の実行時状態 (利用者ごと)。定義は dashboard/gameday.seed.json (コミット対象) が正で、
# 実体は dev サーバ / ビルドが seed から生成し、npm run reset が seed から作り直す
dashboard/public/data/gameday.json

# CDK context with account-specific data (commit cdk.json, ignore local)
cdk.context.json

# Synthetics build artifacts
canaries/**/node_modules/
*.zip

# AWS / secrets
.env
.env.*
*.pem
credentials

# Editor / OS
.DS_Store
*.log

# Claude Code local overrides
.claude/settings.local.json
cdk-outputs.json

exports[`snapshot: 本流 3 スタック (App / Observability / Fis) > Fis 1`] = `
{
  "Outputs": {
    "FailoverDbTemplateId": {
      "Description": "シナリオ2: aws fis start-experiment --experiment-template-id <これ>",
      "Value": {
        "Fn::GetAtt": [
          "FailoverDb",
          "Id",
        ],
      },
    },
    "StopTaskTemplateId": {
      "Description": "シナリオ1: aws fis start-experiment --experiment-template-id <これ>",
      "Value": {
        "Fn::GetAtt": [
          "StopOneTask",
          "Id",
        ],
      },
    },
  },
  "Parameters": {
    "BootstrapVersion": {
      "Default": "/cdk-bootstrap/hnb659fds/version",
      "Description": "Version of the CDK Bootstrap resources in this environment, automatically retrieved from SSM Parameter Store. [cdk:skip]",
      "Type": "AWS::SSM::Parameter::Value<String>",
    },
  },
  "Resources": {
    "FailoverDb": {
      "Properties": {
        "Actions": {
          "Failover": {
            "ActionId": "aws:rds:failover-db-cluster",
            "Description": "Force an Aurora cluster failover",
            "Targets": {
              "Clusters": "Clusters",
            },
          },
        },
        "Description": "GameDay: Aurora をフェイルオーバーし、書き込み先切替時の挙動を観察する",
        "RoleArn": {
          "Fn::GetAtt": [
            "FisRdsRoleA8D5B27B",
            "Arn",
          ],
        },
        "StopConditions": [
          {
            "Source": "aws:cloudwatch:alarm",
            "Value": {
              "Fn::ImportValue": "Obs:ExportsOutputFnGetAttHttp5xxStopAlarmB47064CFArn5D42F46B",
            },
          },
        ],
        "Tags": {
          "Name": "gameday-failover-db",
        },
        "Targets": {
          "Clusters": {
            "ResourceArns": [
              {
                "Fn::Join": [
                  "",
                  [
                    "arn:",
                    {
                      "Ref": "AWS::Partition",
                    },
                    ":rds:",
                    {
                      "Ref": "AWS::Region",
                    },
                    ":",
                    {
                      "Ref": "AWS::AccountId",
                    },
                    ":cluster:",
                    {
                      "Fn::ImportValue": "App:ExportsOutputRefDatabaseB269D8BB88F4B1C4",
                    },
                  ],
                ],
              },
            ],
            "ResourceType": "aws:rds:cluster",
            "SelectionMode": "ALL",
          },
        },
      },
      "Type": "AWS::FIS::ExperimentTemplate",
    },
    "FisEcsRoleCB8E43DC": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "fis.amazonaws.com",
              },
            },
          ],
          "Version": "2012-10-17",
        },
        "Description": "GameDay FIS role (ECS stop-task)",
        "ManagedPolicyArns": [
          {
            "Fn::Join": [
              "",
              [
                "arn:",
                {
                  "Ref": "AWS::Partition",
                },
                ":iam::aws:policy/service-role/AWSFaultInjectionSimulatorECSAccess",
              ],
            ],
          },
        ],
      },
      "Type": "AWS::IAM::Role",
    },
    "FisEcsRoleDefaultPolicyFD85F3E9": {
      "Properties": {
        "PolicyDocument": {
          "Statement": [
            {
              "Action": "cloudwatch:DescribeAlarms",
              "Effect": "Allow",
              "Resource": "*",
            },
          ],
          "Version": "2012-10-17",
        },
        "PolicyName": "FisEcsRoleDefaultPolicyFD85F3E9",
        "Roles": [
          {
            "Ref": "FisEcsRoleCB8E43DC",
          },
        ],
      },
      "Type": "AWS::IAM::Policy",
    },
    "FisRdsRoleA8D5B27B": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "fis.amazonaws.com",
              },
            },
          ],
          "Version": "2012-10-17",
        },
        "Description": "GameDay FIS role (RDS failover)",
        "ManagedPolicyArns": [
          {
            "Fn::Join": [
              "",
              [
                "arn:",
                {
                  "Ref": "AWS::Partition",
                },
                ":iam::aws:policy/service-role/AWSFaultInjectionSimulatorRDSAccess",
              ],
            ],
          },
        ],
      },
      "Type": "AWS::IAM::Role",
    },
    "FisRdsRoleDefaultPolicy6934E5EC": {
      "Properties": {
        "PolicyDocument": {
          "Statement": [
            {
              "Action": "cloudwatch:DescribeAlarms",
              "Effect": "Allow",
              "Resource": "*",
            },
          ],
          "Version": "2012-10-17",
        },
        "PolicyName": "FisRdsRoleDefaultPolicy6934E5EC",
        "Roles": [
          {
            "Ref": "FisRdsRoleA8D5B27B",
          },
        ],
      },
      "Type": "AWS::IAM::Policy",
    },
    "StopOneTask": {
      "Properties": {
        "Actions": {
          "StopTask": {
            "ActionId": "aws:ecs:stop-task",
            "Description": "Stop one targeted Fargate task",
            "Targets": {
              "Tasks": "Tasks",
            },
          },
        },
        "Description": "GameDay: Fargate タスクを 1 つ停止し、冗長性と回復を観察する",
        "RoleArn": {
          "Fn::GetAtt": [
            "FisEcsRoleCB8E43DC",
            "Arn",
          ],
        },
        "StopConditions": [
          {
            "Source": "aws:cloudwatch:alarm",
            "Value": {
              "Fn::ImportValue": "Obs:ExportsOutputFnGetAttHttp5xxStopAlarmB47064CFArn5D42F46B",
            },
          },
        ],
        "Tags": {
          "Name": "gameday-stop-one-task",
        },
        "Targets": {
          "Tasks": {
            "ResourceTags": {
              "GameDayTarget": "true",
            },
            "ResourceType": "aws:ecs:task",
            "SelectionMode": "COUNT(1)",
          },
        },
      },
      "Type": "AWS::FIS::ExperimentTemplate",
    },
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5",
                  ],
                  {
                    "Ref": "BootstrapVersion",
                  },
                ],
              },
            ],
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI.",
        },
      ],
    },
  },
}
`;


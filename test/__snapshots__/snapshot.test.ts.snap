        "ImageId": {
          "Ref": "SsmParameterValueawsserviceamiamazonlinuxlatestal2023amikernel61x8664C96584B6F00A464EAD1953AFF4B05118Parameter",
        },
        "InstanceType": "t3.micro",
        "SecurityGroupIds": [
          {
            "Fn::GetAtt": [
              "AppSg898BCA4E",
              "GroupId",
            ],
          },
        ],
        "SubnetId": {
          "Ref": "VpcappSubnet1SubnetAE489B2F",
        },
        "Tags": [
          {
            "Key": "GameDayScenario",
            "Value": "03",
          },
          {
            "Key": "Name",
            "Value": "Legacy/LegacyServer",
          },
        ],
        "UserData": {
          "Fn::Base64": {
            "Fn::Join": [
              "",
              [
                "#!/bin/bash
set -euo pipefail
dnf install -y docker
systemctl enable --now docker
aws ecr get-login-password --region ",
                {
                  "Ref": "AWS::Region",
                },
                " | docker login --username AWS --password-stdin ",
                {
                  "Ref": "AWS::AccountId",
                },
                ".dkr.ecr.",
                {
                  "Ref": "AWS::Region",
                },
                ".amazonaws.com
DB_SECRET=$(aws secretsmanager get-secret-value --region ",
                {
                  "Ref": "AWS::Region",
                },
                " --secret-id ",
                {
                  "Ref": "DatabaseSecretAttachmentE5D1B020",
                },
                " --query SecretString --output text)
docker run -d --restart always -p 80:80 -e DB_HOST=",
                {
                  "Fn::GetAtt": [
                    "DatabaseB269D8BB",
                    "Endpoint.Address",
                  ],
                },
                " -e DB_PORT=",
                {
                  "Fn::GetAtt": [
                    "DatabaseB269D8BB",
                    "Endpoint.Port",
                  ],
                },
                " -e DB_NAME=gameday -e DB_SECRET="$DB_SECRET" ",
                {
                  "Fn::Sub": "\${AWS::AccountId}.dkr.ecr.\${AWS::Region}.\${AWS::URLSuffix}/cdk-hnb659fds-container-assets-\${AWS::AccountId}-\${AWS::Region}:[ASSET_HASH]",
                },
              ],
            ],
          },
        },
      },
      "Type": "AWS::EC2::Instance",
    },

    "ObservabilityHttp5xxStopAlarmFC175C42": {
      "Properties": {
        "AlarmDescription": "FIS 停止条件: 5xx が想定の爆発半径を超えたら実験を止める",
        "AlarmName": "gameday-5xx-stop-condition",
        "ComparisonOperator": "GreaterThanThreshold",
        "EvaluationPeriods": 1,
        "Metrics": [
          {
            "Expression": "elb + target",
            "Id": "expr_1",
            "ReturnData": true,
          },
          {
            "Id": "elb",
            "MetricStat": {
              "Metric": {
                "Dimensions": [
                  {
                    "Name": "LoadBalancer",
                    "Value": {
                      "Fn::GetAtt": [
                        "TargetAppAlb331E44A3",
                        "LoadBalancerFullName",
                      ],
                    },
                  },
                ],
                "MetricName": "HTTPCode_ELB_5XX_Count",
                "Namespace": "AWS/ApplicationELB",
              },
              "Period": 60,
              "Stat": "Sum",
            },
            "ReturnData": false,
          },
          {
            "Id": "target",
            "MetricStat": {
              "Metric": {
                "Dimensions": [
                  {
                    "Name": "LoadBalancer",
                    "Value": {
                      "Fn::Join": [
                        "",
                        [
                          {
                            "Fn::Select": [
                              1,
                              {
                                "Fn::Split": [
                                  "/",
                                  {
                                    "Ref": "TargetAppAlbHttp73F81286",
                                  },
                                ],
                              },
                            ],
                          },
                          "/",
                          {
                            "Fn::Select": [
                              2,
                              {
                                "Fn::Split": [
                                  "/",
                                  {
                                    "Ref": "TargetAppAlbHttp73F81286",
                                  },
                                ],
                              },
                            ],
                          },
                          "/",
                          {
                            "Fn::Select": [
                              3,
                              {
                                "Fn::Split": [
                                  "/",
                                  {
                                    "Ref": "TargetAppAlbHttp73F81286",
                                  },
                                ],
                              },
                            ],
                          },
                        ],
                      ],
                    },
                  },
                  {
                    "Name": "TargetGroup",
                    "Value": {
                      "Fn::GetAtt": [
                        "TargetAppAlbHttpEcsGroup8B424B3D",
                        "TargetGroupFullName",
                      ],
                    },
                  },
                ],
                "MetricName": "HTTPCode_Target_5XX_Count",
                "Namespace": "AWS/ApplicationELB",
              },
              "Period": 60,
              "Stat": "Sum",
            },
            "ReturnData": false,
          },
        ],
        "Threshold": 10,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "ObservabilityReviewDashboard615A6C23": {
      "Properties": {
        "DashboardBody": {
          "Fn::Join": [

    "TargetAppTaskDef386EF395": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "Environment": [
              {
                "Name": "DB_HOST",
                "Value": {
                  "Fn::GetAtt": [
                    "TargetAppDatabase0D891808",
                    "Endpoint.Address",
                  ],
                },
              },
              {
                "Name": "DB_PORT",
                "Value": {
                  "Fn::GetAtt": [
                    "TargetAppDatabase0D891808",
                    "Endpoint.Port",
                  ],
                },
              },
              {
                "Name": "DB_NAME",
                "Value": "gameday",
              },
            ],
            "Essential": true,
            "Image": {
              "Fn::Join": [
                "",
                [
                  {
                    "Fn::Select": [
                      4,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::GetAtt": [
                              "TargetAppAppImageRepository14F3CF93",
                              "Arn",
                            ],
                          },
                        ],
                      },
                    ],
                  },
                  ".dkr.ecr.",
                  {
                    "Fn::Select": [
                      3,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::GetAtt": [
                              "TargetAppAppImageRepository14F3CF93",
                              "Arn",
                            ],
                          },
                        ],
                      },
                    ],
                  },
                  ".",
                  {
                    "Ref": "AWS::URLSuffix",
                  },
                  "/",
                  {
                    "Ref": "TargetAppAppImageRepository14F3CF93",
                  },
                  ":",
                  {
                    "Fn::GetAtt": [
                      "TargetAppAppImage903B932A",
                      "ImageTag",
                    ],
                  },
                ],
              ],
            },
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "TargetAppTaskDefappLogGroup9825EAAF",
                },
                "awslogs-region": {
                  "Ref": "AWS::Region",
                },
                "awslogs-stream-prefix": "gameday-app",
              },
            },
            "Name": "app",
            "PortMappings": [
              {
                "ContainerPort": 80,
                "Protocol": "tcp",
              },
            ],
            "Secrets": [
              {
                "Name": "DB_SECRET",
                "ValueFrom": {
                  "Ref": "TargetAppDatabaseSecretAttachmentA27C7923",
                },
              },
            ],
          },
        ],
        "Cpu": "256",
        "ExecutionRoleArn": {
          "Fn::GetAtt": [
            "TargetAppTaskDefExecutionRoleD6B9A797",
            "Arn",
          ],
        },
        "Family": "GameDayTargetAppTaskDef73289CE3",
        "Memory": "512",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE",
        ],
        "TaskRoleArn": {
          "Fn::GetAtt": [
            "TargetAppTaskDefTaskRole01D03140",
            "Arn",
          ],
        },
      },
      "Type": "AWS::ECS::TaskDefinition",
    },

                  {
                    "Fn::Split": [
                      "/",
                      {
                        "Ref": "AlbHttp7966E42E",
                      },
                    ],
                  },
                ],
              },
              "/",
              {
                "Fn::Select": [
                  2,
                  {
                    "Fn::Split": [
                      "/",
                      {
                        "Ref": "AlbHttp7966E42E",
                      },
                    ],
                  },
                ],
              },
              "/",
              {
                "Fn::Select": [
                  3,
                  {
                    "Fn::Split": [
                      "/",
                      {
                        "Ref": "AlbHttp7966E42E",
                      },
                    ],
                  },
                ],
              },
              "","TargetGroup","",
              {
                "Fn::GetAtt": [
                  "AppTgBEDAABDD",
                  "TargetGroupFullName",
                ],
              },
              "",{"yAxis":"right"}]],"yAxis":{}}}]}",
            ],
          ],
        },
        "DashboardName": "gameday-legacy-review",
      },
      "Type": "AWS::CloudWatch::Dashboard",
    },
    "TerminateEc2Experiment": {
      "Properties": {
        "Actions": {
          "Terminate": {
            "ActionId": "aws:ec2:terminate-instances",
            "Description": "Terminate the single SPOF EC2 instance",
            "Targets": {
              "Instances": "SpofInstance",
            },
          },
        },
        "Description": "scenario-03: 単一 EC2 (SPOF) を terminate。参加者が ECS 化で復旧する",
        "ExperimentReportConfiguration": {
          "DataSources": {
            "CloudWatchDashboards": [
              {
                "DashboardIdentifier": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":cloudwatch::",
                      {
                        "Ref": "AWS::AccountId",
                      },
                      ":dashboard/gameday-legacy-review",
                    ],
                  ],
                },
              },
            ],
          },
          "Outputs": {
            "ExperimentReportS3Configuration": {
              "BucketName": {
                "Ref": "FisReportBucketFF54701A",
              },
              "Prefix": "scenario-03/",
            },
          },
          "PostExperimentDuration": "PT75M",
          "PreExperimentDuration": "PT10M",
        },
        "RoleArn": {
          "Fn::GetAtt": [
            "FisRoleF2C479C1",
            "Arn",
          ],
        },
        "StopConditions": [
          {
            "Source": "aws:cloudwatch:alarm",
            "Value": {
              "Fn::GetAtt": [
                "AbortAlarm0223496C",
                "Arn",
              ],
            },
          },
        ],
        "Tags": {
          "Name": "gameday-scenario-03-terminate-ec2",
          "gameday": "true",
        },
        "Targets": {
          "SpofInstance": {
            "Filters": [
              {
                "Path": "VpcId",
                "Values": [
                  {
                    "Ref": "Vpc8378EB38",
                  },
                ],
              },
              {
                "Path": "State.Name",
                "Values": [
                  "running",
                ],
              },
            ],
            "ResourceTags": {
              "GameDayScenario": "03",
            },
            "ResourceType": "aws:ec2:instance",
            "SelectionMode": "COUNT(1)",
          },
        },
      },
      "Type": "AWS::FIS::ExperimentTemplate",
    },

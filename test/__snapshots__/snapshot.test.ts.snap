    "FaultInjectionScaleToZeroDoc43454D6F": {
      "Properties": {
        "Content": {
          "assumeRole": "{{ AutomationAssumeRole }}",
          "description": "GameDay: set the target ECS service desiredCount to 0 (no auto-recovery)",
          "mainSteps": [
            {
              "action": "aws:executeAwsApi",
              "inputs": {
                "Api": "UpdateService",
                "Service": "ecs",
                "cluster": "{{ Cluster }}",
                "desiredCount": 0,
                "service": "{{ Service }}",
              },
              "name": "ScaleToZero",
            },
          ],
          "parameters": {
            "AutomationAssumeRole": {
              "type": "String",
            },
            "Cluster": {
              "type": "String",
            },
            "Service": {
              "type": "String",
            },
          },
          "schemaVersion": "0.3",
        },
        "DocumentFormat": "JSON",
        "DocumentType": "Automation",
      },
      "Type": "AWS::SSM::Document",
    },

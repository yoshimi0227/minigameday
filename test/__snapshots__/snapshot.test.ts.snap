    "LegacyServer648CAC27": {
      "DependsOn": [
        "LegacyServerInstanceRoleDefaultPolicyE111068F",
        "LegacyServerInstanceRole8679AF5D",
      ],
      "Properties": {
        "AvailabilityZone": {
          "Fn::Select": [
